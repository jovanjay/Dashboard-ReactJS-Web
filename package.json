{
  "name": "dashboard-reactjs-web",
  "version": "2.0.0",
  "private": true,
  "main": "electron/main.js",
  "dependencies": {
    "@amcharts/amcharts4": "^4.10.20",
    "@amcharts/amcharts4-geodata": "^4.1.21",
    "@material-ui/core": "^4.12.3",
    "@material-ui/icons": "^4.11.2",
    "axios": "^1.8.4",
    "axios-mock-adapter": "^1.19.0",
    "bootstrap": "^5.3.5",
    "caniuse-lite": "^1.0.30001793",
    "formik": "^2.2.9",
    "immutable": "^4.0.0-rc.14",
    "local-storage": "^2.0.0",
    "namor": "^1.1.3",
    "react": "^18.3.1",
    "react-bootstrap": "^1.6.4",
    "react-bootstrap-typeahead": "^3.4.7",
    "react-burger-menu": "^3.0.9",
    "react-calendar": "^5.1.0",
    "react-dom": "^18.3.1",
    "react-redux": "^7.2.9",
    "react-router-dom": "^5.3.4",
    "react-table": "^7.8.0",
    "redux": "^4.2.1",
    "redux-thunk": "^2.4.2",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.3.0",
    "electron-builder": "^25.1.8",
    "version-bump-prompt": "^4.1.0",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.fuze.dashboard",
    "productName": "Fuze Dashboard",
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
